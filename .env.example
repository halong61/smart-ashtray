# ── 서버 ──────────────────────────────
SERVER_IP=
FRONTEND_URL=

# ── MQTT 브로커 (Mosquitto) ───────────
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_WS_PORT=9001
MQTT_USERNAME=
MQTT_PASSWORD=

# ── 데이터베이스 (TimescaleDB) ─────────
POSTGRES_USER=ashtray_user
POSTGRES_PASSWORD=
POSTGRES_DB=ashtray_db
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ── 인증 (JWT) ─────────────────────────
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── 이메일 (Gmail SMTP) ────────────────
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# ── ESP32 MQTT 토픽 (참고용) ──────────
GEMINI_API_KEY=
